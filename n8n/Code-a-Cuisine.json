    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output;\nconst cleaned = raw.replace(/```json|```/g, '').trim();\nconst recipes = JSON.parse(cleaned);\n\nif (recipes.length !== 3) {\n  throw new Error(`KI hat ${recipes.length} Rezepte generiert, erwartet waren 3.`);\n}\n\n// cookbook_id neu berechnen aus Webhook Daten\nconst webhook = $('Webhook').item.json.body;\nconst ingredients = webhook.ingredients\n  .map(i => `${i.size}${i.unit}${i.value.toLowerCase()}`)\n  .sort()\n  .join('|');\n\nconst key = `${ingredients}_${webhook.selectedCookingTime}_${webhook.selectedCuisines}_${webhook.selectedDietPreference}_${webhook.person}_${webhook.portions}`.toLowerCase();\n\nlet hash = 0;\nfor (let i = 0; i < key.length; i++) {\n  hash = ((hash << 5) - hash) + key.charCodeAt(i);\n  hash |= 0;\n}\nconst cookbook_id = Math.abs(hash).toString(16);\n\nreturn recipes.map(recipe => ({ \n  json: {\n    recipe: {\n      title: recipe.title,\n      info: recipe.info,\n      nutritional: recipe.nutritional,\n      ingredients: recipe.ingredients,\n      directions: recipe.directions\n    },\n    cookbook_id: cookbook_id,\n    selectedCuisines: recipe.info.cuisine,\n    selectedDietPreference: recipe.info.confidence\n  }\n}));"
      },
