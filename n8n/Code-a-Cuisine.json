      "parameters": {
        "jsCode": "const row = $input.first().json;\nconst requestCount = row.count;\nconst lastRequest = $input.first().json['last request']\n\n// Mitternacht heute\nconst midnight = new Date();\nmidnight.setHours(0, 0, 0, 0);\n\n\nconst limitReached = requestCount >= 3;\n\n// can_request = false wenn limit erreicht UND kein neuer Tag\nconst can_request = limitReached ? false : true;\n\nreturn [{ json: {\n  ...row,\n  limit_reached: limitReached,\n  can_request: can_request\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
